        <mxCell id="aux-vpce" value="VPC Endpoints&#xa;S3 / Bedrock / SQS&#xa;NAT 不要・低レイテンシ" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#7AA116;fontSize=9;verticalAlign=middle;align=center;" vertex="1" parent="1">
          <mxGeometry x="560" y="420" width="160" height="50" as="geometry"/>
        </mxCell>

        <!-- ====== Cost / Notes ====== -->
        <mxCell id="notes-box" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF8E1;strokeColor=#D6B656;strokeWidth=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="525" width="700" height="320" as="geometry"/>
        </mxCell>
        <mxCell id="notes-title" value="💡 設計ノート（AWS 固有）" style="text;html=1;fontSize=12;fontStyle=1;align=left;verticalAlign=middle;fontColor=#9C7A0F;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="50" y="530" width="400" height="22" as="geometry"/>
        </mxCell>

        <mxCell id="notes-1" value="◆ WebSocket は API Gateway WebSocket API で受け、$connect / $disconnect / $default で接続管理&#xa;　 connectionId を ElastiCache に保存しておけば後段からの postToConnection で字幕を Fan-out できる" style="text;html=1;fontSize=10;align=left;verticalAlign=top;fontColor=#333333;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="50" y="555" width="680" height="40" as="geometry"/>
        </mxCell>
        <mxCell id="notes-2" value="◆ Quick レーンは ECS on EC2 (g5.xlarge) を最低 1 台常時起動。Service Auto Scaling で同時会議数に応じてスケール&#xa;　 Refinement / Final は Capacity Provider + SageMaker Async でゼロスケール可能（コスト最適）" style="text;html=1;fontSize=10;align=left;verticalAlign=top;fontColor=#333333;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="50" y="600" width="680" height="40" as="geometry"/>
        </mxCell>
        <mxCell id="notes-3" value="◆ ASR-7B モデル本体は S3 に置き、ECS タスク起動時に EFS / インスタンスストアへキャッシュ&#xa;　 vLLM 起動時間を 30 秒未満に抑える（コールドスタート時の体感を悪化させない）" style="text;html=1;fontSize=10;align=left;verticalAlign=top;fontColor=#333333;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="50" y="645" width="680" height="40" as="geometry"/>
        </mxCell>
        <mxCell id="notes-4" value="◆ LLM 要約は Bedrock の Claude を直接呼び出し（プロンプトキャッシュで議題テンプレートをキャッシュ可）&#xa;　 Guardrails で個人情報マスキングを噛ませると社内議事録での PII 漏洩リスクを下げられる" style="text;html=1;fontSize=10;align=left;verticalAlign=top;fontColor=#333333;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="50" y="690" width="680" height="40" as="geometry"/>
        </mxCell>
        <mxCell id="notes-5" value="◆ コスト試算（1日10セッション・各60分・東京リージョン）の概算&#xa;　 g5.xlarge×1 常時 ≒ $750/月、g5.2xlarge スポット ≒ $200/月、SageMaker Async ≒ 推論時間課金 ≒ $50/月、&#xa;　 Bedrock Claude Sonnet ≒ $30/月、S3+Aurora+ElastiCache+SQS ≒ $150/月 → 概ね月 $1,200 前後" style="text;html=1;fontSize=10;align=left;verticalAlign=top;fontColor=#333333;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="50" y="735" width="680" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="notes-6" value="◆ DR / マルチリージョン: Aurora Global Database + S3 Cross-Region Replication で東京⇄大阪フェイルオーバー対応" style="text;html=1;fontSize=10;align=left;verticalAlign=top;fontColor=#333333;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="50" y="800" width="680" height="40" as="geometry"/>
        </mxCell>

        <!-- ====== Arrows ====== -->
        <!-- Client → Edge -->
        <mxCell id="arr-client-edge" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#6c8ebf;strokeWidth=2;endArrow=blockThin;endFill=1;startArrow=blockThin;startFill=1;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" parent="1" source="client-box" target="edge-box">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Edge → APIGW -->
        <mxCell id="arr-edge-apigw" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#FF9900;strokeWidth=2;endArrow=blockThin;endFill=1;startArrow=blockThin;startFill=1;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" parent="1" source="edge-box" target="apigw-box">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- APIGW → ECS Fargate -->
        <mxCell id="arr-apigw-app" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7AA116;strokeWidth=2;endArrow=blockThin;endFill=1;startArrow=blockThin;startFill=1;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" parent="1" source="apigw-box" target="app-box">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- App → SQS -->
        <mxCell id="arr-app-sqs" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#FF9900;strokeWidth=2;endArrow=blockThin;endFill=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="app-box" target="sqs-box">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- App → ElastiCache -->
        <mxCell id="arr-app-cache" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#3334B9;strokeWidth=2;endArrow=blockThin;endFill=1;startArrow=blockThin;startFill=1;exitX=1;exitY=0.7;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" parent="1" source="app-box" target="cache-box">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- SQS → Inference -->
        <mxCell id="arr-sqs-inf" value="poll" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#DD344C;strokeWidth=2;endArrow=blockThin;endFill=1;fontSize=9;fontColor=#DD344C;labelBackgroundColor=#FFFFFF;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="sqs-box" target="inf-box">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- StepFunctions → Inference (Final) -->
        <mxCell id="arr-sfn-inf" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#DD344C;strokeWidth=1.5;endArrow=blockThin;endFill=1;dashed=1;exitX=0;exitY=1;exitDx=0;exitDy=0;entryX=1;entryY=0.85;entryDx=0;entryDy=0;" edge="1" parent="1" source="sfn-box" target="inf-box">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- StepFunctions → Bedrock -->
        <mxCell id="arr-sfn-llm" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#DD344C;strokeWidth=2;endArrow=blockThin;endFill=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="sfn-box" target="llm-box">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Inference → Cache (publish) -->
        <mxCell id="arr-inf-cache" value="publish 暫定/補正" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#3334B9;strokeWidth=1.5;endArrow=blockThin;endFill=1;fontSize=9;fontColor=#3334B9;labelBackgroundColor=#FFFFFF;exitX=1;exitY=0.2;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" parent="1" source="inf-box" target="cache-box">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- LLM → Storage -->
        <mxCell id="arr-llm-store" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7C3FA9;strokeWidth=1.5;endArrow=blockThin;endFill=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="llm-box" target="store-box">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- App → Storage -->
        <mxCell id="arr-app-store-aws" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#7C3FA9;strokeWidth=1.5;endArrow=blockThin;endFill=1;startArrow=blockThin;startFill=1;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.7;entryDx=0;entryDy=0;dashed=1;" edge="1" parent="1" source="app-box" target="store-box">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>

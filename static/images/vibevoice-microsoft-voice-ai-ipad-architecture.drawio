<mxfile host="app.diagrams.net" agent="Claude Code" version="26.0.0">
  <diagram id="vibevoice-ipad-arch" name="VibeVoice iPad/iPhone Architecture">
    <mxGraphModel dx="1200" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1200" pageHeight="780" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- Title -->
        <mxCell id="title" value="iPad / iPhone を入力端末とする VibeVoice システム構成" style="text;html=1;fontSize=16;fontStyle=1;align=center;verticalAlign=middle;whiteSpace=wrap;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="200" y="10" width="800" height="30" as="geometry"/>
        </mxCell>
        <mxCell id="subtitle" value="クライアント（iOS/iPadOS）はマイク入力と再生のみ。重い推論はサーバ側 GPU で実行。" style="text;html=1;fontSize=10;align=center;verticalAlign=middle;fontColor=#888888;fontStyle=2;" vertex="1" parent="1">
          <mxGeometry x="200" y="40" width="800" height="20" as="geometry"/>
        </mxCell>

        <!-- ============== Client Layer ============== -->
        <mxCell id="client-box" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;strokeWidth=1.5;" vertex="1" parent="1">
          <mxGeometry x="40" y="80" width="290" height="640" as="geometry"/>
        </mxCell>
        <mxCell id="client-title" value="📱 Client（iPad / iPhone）" style="text;html=1;fontSize=13;fontStyle=1;align=left;verticalAlign=middle;fontColor=#6c8ebf;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="50" y="86" width="270" height="25" as="geometry"/>
        </mxCell>
        <mxCell id="client-desc" value="入力デバイス専任 — 推論はしない" style="text;html=1;fontSize=9;align=left;verticalAlign=middle;fontColor=#6c8ebf;fontStyle=2;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="50" y="108" width="270" height="18" as="geometry"/>
        </mxCell>

        <mxCell id="client-app" value="ネイティブアプリ または PWA（Safari）" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#6c8ebf;fontSize=11;fontStyle=1;verticalAlign=middle;align=center;" vertex="1" parent="1">
          <mxGeometry x="55" y="135" width="260" height="40" as="geometry"/>
        </mxCell>

        <mxCell id="client-mic" value="🎤 マイク入力&#xa;(AVAudioEngine /&#xa;getUserMedia)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#6c8ebf;fontSize=10;verticalAlign=middle;align=center;" vertex="1" parent="1">
          <mxGeometry x="55" y="190" width="125" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="client-spk" value="🔈 スピーカー再生&#xa;(AVAudioPlayer /&#xa;Web Audio API)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#6c8ebf;fontSize=10;verticalAlign=middle;align=center;" vertex="1" parent="1">
          <mxGeometry x="190" y="190" width="125" height="60" as="geometry"/>
        </mxCell>

        <mxCell id="client-encode" value="音声エンコード&#xa;PCM 16kHz / Opus / AAC" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#6c8ebf;fontSize=10;verticalAlign=middle;align=center;" vertex="1" parent="1">
          <mxGeometry x="55" y="265" width="260" height="45" as="geometry"/>
        </mxCell>

        <mxCell id="client-vad" value="任意: VAD（音声区間検出）&#xa;Apple純正 SFSpeechRecognizer や WebRTC VAD で&#xa;送信前に無音区間をトリミング" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#6c8ebf;fontSize=9;verticalAlign=middle;align=center;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="55" y="325" width="260" height="50" as="geometry"/>
        </mxCell>

        <!-- Use cases -->
        <mxCell id="usecase-title" value="ユースケース" style="text;html=1;fontSize=11;fontStyle=1;align=left;verticalAlign=middle;fontColor=#6c8ebf;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="50" y="395" width="270" height="20" as="geometry"/>
        </mxCell>
        <mxCell id="uc1" value="① 60分の長尺録音 → 文字起こし依頼&#xa;（会議・取材・ポッドキャスト）" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=9;verticalAlign=middle;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="55" y="420" width="260" height="42" as="geometry"/>
        </mxCell>
        <mxCell id="uc2" value="② リアルタイム文字起こし&#xa;（マイク → ストリーミング ASR）" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=9;verticalAlign=middle;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="55" y="472" width="260" height="42" as="geometry"/>
        </mxCell>
        <mxCell id="uc3" value="③ テキスト → 音声合成（Realtime TTS）&#xa;（読み上げ・ナレーション・対話 UI）" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=9;verticalAlign=middle;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="55" y="524" width="260" height="42" as="geometry"/>
        </mxCell>

        <!-- Auth -->
        <mxCell id="client-auth" value="🔐 認証&#xa;OAuth 2.0 / JWT&#xa;Keychain で安全保管" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#6c8ebf;fontSize=9;verticalAlign=middle;align=center;" vertex="1" parent="1">
          <mxGeometry x="55" y="585" width="260" height="50" as="geometry"/>
        </mxCell>

        <mxCell id="client-note" value="ポイント: モデル本体は端末に置かない。&#xa;ローカルは録音/再生/UI のみ → バッテリ・発熱を抑制。" style="text;html=1;fontSize=9;align=center;verticalAlign=middle;fontColor=#6c8ebf;fontStyle=2;" vertex="1" parent="1">
          <mxGeometry x="55" y="650" width="260" height="60" as="geometry"/>
        </mxCell>

        <!-- ============== Edge Layer ============== -->
        <mxCell id="edge-box" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;strokeWidth=1.5;" vertex="1" parent="1">
          <mxGeometry x="370" y="80" width="220" height="640" as="geometry"/>
        </mxCell>
        <mxCell id="edge-title" value="🌐 Edge / Gateway" style="text;html=1;fontSize=13;fontStyle=1;align=left;verticalAlign=middle;fontColor=#b58e00;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="380" y="86" width="200" height="25" as="geometry"/>
        </mxCell>
        <mxCell id="edge-desc" value="TLS 終端・流量制御" style="text;html=1;fontSize=9;align=left;verticalAlign=middle;fontColor=#b58e00;fontStyle=2;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="380" y="108" width="200" height="18" as="geometry"/>
        </mxCell>

        <mxCell id="edge-cdn" value="Cloudflare / CDN&#xa;DDoS 対策・キャッシュ" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#d6b656;fontSize=10;verticalAlign=middle;align=center;" vertex="1" parent="1">
          <mxGeometry x="385" y="135" width="195" height="50" as="geometry"/>
        </mxCell>

        <mxCell id="edge-proxy" value="Reverse Proxy&#xa;Nginx / Caddy / Traefik&#xa;・TLS 終端&#xa;・WebSocket アップグレード&#xa;・gzip/brotli 圧縮" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#d6b656;fontSize=9;verticalAlign=middle;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="385" y="200" width="195" height="100" as="geometry"/>
        </mxCell>

        <mxCell id="edge-auth" value="API Gateway&#xa;・OAuth/JWT 検証&#xa;・レート制限&#xa;・WAF" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#d6b656;fontSize=9;verticalAlign=middle;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="385" y="315" width="195" height="80" as="geometry"/>
        </mxCell>

        <!-- Protocols -->
        <mxCell id="proto-title" value="プロトコル" style="text;html=1;fontSize=10;fontStyle=1;align=left;verticalAlign=middle;fontColor=#b58e00;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="385" y="410" width="195" height="20" as="geometry"/>
        </mxCell>
        <mxCell id="proto1" value="HTTPS POST /asr/jobs&#xa;(長尺音声アップロード)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#d6b656;fontSize=9;verticalAlign=middle;align=left;spacingLeft=6;fontFamily=monospace;" vertex="1" parent="1">
          <mxGeometry x="385" y="435" width="195" height="40" as="geometry"/>
        </mxCell>
        <mxCell id="proto2" value="WebSocket /asr/stream&#xa;(リアルタイム ASR)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#d6b656;fontSize=9;verticalAlign=middle;align=left;spacingLeft=6;fontFamily=monospace;" vertex="1" parent="1">
          <mxGeometry x="385" y="485" width="195" height="40" as="geometry"/>
        </mxCell>
        <mxCell id="proto3" value="WebSocket /tts/stream&#xa;(リアルタイム TTS)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#d6b656;fontSize=9;verticalAlign=middle;align=left;spacingLeft=6;fontFamily=monospace;" vertex="1" parent="1">
          <mxGeometry x="385" y="535" width="195" height="40" as="geometry"/>
        </mxCell>
        <mxCell id="proto4" value="SSE GET /asr/jobs/:id&#xa;(進捗ストリーム)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#d6b656;fontSize=9;verticalAlign=middle;align=left;spacingLeft=6;fontFamily=monospace;" vertex="1" parent="1">
          <mxGeometry x="385" y="585" width="195" height="40" as="geometry"/>
        </mxCell>

        <mxCell id="edge-note" value="リアルタイム TTS は &lt;300ms&#xa;が目標 → WebSocket 推奨" style="text;html=1;fontSize=9;align=center;verticalAlign=middle;fontColor=#b58e00;fontStyle=2;" vertex="1" parent="1">
          <mxGeometry x="385" y="635" width="195" height="40" as="geometry"/>
        </mxCell>

        <!-- ============== Application Layer ============== -->
        <mxCell id="app-box" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;strokeWidth=1.5;" vertex="1" parent="1">
          <mxGeometry x="630" y="80" width="270" height="380" as="geometry"/>
        </mxCell>
        <mxCell id="app-title" value="⚙️ Application Server" style="text;html=1;fontSize=13;fontStyle=1;align=left;verticalAlign=middle;fontColor=#82b366;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="640" y="86" width="250" height="25" as="geometry"/>
        </mxCell>
        <mxCell id="app-desc" value="API ロジック・ジョブオーケストレーション" style="text;html=1;fontSize=9;align=left;verticalAlign=middle;fontColor=#82b366;fontStyle=2;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="640" y="108" width="250" height="18" as="geometry"/>
        </mxCell>

        <mxCell id="app-fastapi" value="FastAPI / Express&#xa;・REST + WebSocket エンドポイント&#xa;・ジョブ管理&#xa;・OpenAPI スキーマ" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#82b366;fontSize=10;verticalAlign=middle;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="640" y="135" width="250" height="80" as="geometry"/>
        </mxCell>

        <mxCell id="app-queue" value="ジョブキュー&#xa;Celery + Redis / RQ / Sidekiq&#xa;・60分 ASR は非同期実行&#xa;・進捗を SSE/WS でクライアントへ" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#82b366;fontSize=10;verticalAlign=middle;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="640" y="230" width="250" height="80" as="geometry"/>
        </mxCell>

        <mxCell id="app-stream" value="ストリーミングルータ&#xa;・音声チャンクを vLLM に転送&#xa;・トークン単位でクライアントに返送" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#82b366;fontSize=10;verticalAlign=middle;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="640" y="325" width="250" height="60" as="geometry"/>
        </mxCell>

        <mxCell id="app-fmt" value="後処理&#xa;ホットワード適用 / 句読点整形 / SRT/VTT 変換" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#82b366;fontSize=9;verticalAlign=middle;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="640" y="395" width="250" height="55" as="geometry"/>
        </mxCell>

        <!-- ============== Inference Layer ============== -->
        <mxCell id="inf-box" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;strokeWidth=1.5;" vertex="1" parent="1">
          <mxGeometry x="940" y="80" width="220" height="380" as="geometry"/>
        </mxCell>
        <mxCell id="inf-title" value="🔥 Inference (GPU)" style="text;html=1;fontSize=13;fontStyle=1;align=left;verticalAlign=middle;fontColor=#b85450;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="950" y="86" width="200" height="25" as="geometry"/>
        </mxCell>
        <mxCell id="inf-desc" value="VibeVoice 本体 / vLLM 推論" style="text;html=1;fontSize=9;align=left;verticalAlign=middle;fontColor=#b85450;fontStyle=2;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="950" y="108" width="200" height="18" as="geometry"/>
        </mxCell>

        <mxCell id="inf-asr" value="VibeVoice-ASR-7B&#xa;・60分1パス処理&#xa;・話者識別+タイムスタンプ&#xa;・50言語対応&#xa;・ホットワード対応" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#b85450;fontSize=10;verticalAlign=middle;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="950" y="135" width="200" height="100" as="geometry"/>
        </mxCell>

        <mxCell id="inf-rt" value="VibeVoice-Realtime-0.5B&#xa;・~300ms 起動&#xa;・ストリーミングテキスト入力&#xa;・9言語ボイス（JP含む）" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#b85450;fontSize=10;verticalAlign=middle;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="950" y="245" width="200" height="90" as="geometry"/>
        </mxCell>

        <mxCell id="inf-gpu" value="GPU リソース&#xa;NVIDIA A10/L4/A100 など&#xa;vLLM で高速推論" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#b85450;fontSize=9;verticalAlign=middle;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="950" y="345" width="200" height="60" as="geometry"/>
        </mxCell>

        <mxCell id="inf-options" value="デプロイ先の選択肢:&#xa;• HF Inference Endpoints&#xa;• RunPod / Modal / Replicate&#xa;• 自宅 GPU + Tailscale" style="text;html=1;fontSize=9;align=left;verticalAlign=middle;fontColor=#b85450;fontStyle=2;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="950" y="410" width="200" height="50" as="geometry"/>
        </mxCell>

        <!-- ============== Storage Layer ============== -->
        <mxCell id="store-box" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;strokeWidth=1.5;" vertex="1" parent="1">
          <mxGeometry x="630" y="480" width="530" height="240" as="geometry"/>
        </mxCell>
        <mxCell id="store-title" value="💾 Storage / State" style="text;html=1;fontSize=13;fontStyle=1;align=left;verticalAlign=middle;fontColor=#9673a6;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="640" y="486" width="510" height="25" as="geometry"/>
        </mxCell>

        <mxCell id="store-s3" value="🎵 オブジェクトストレージ&#xa;S3 / R2 / GCS&#xa;・元音声ファイル&#xa;・生成 TTS 音声&#xa;・有効期限付き署名 URL" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#9673a6;fontSize=10;verticalAlign=middle;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="640" y="520" width="250" height="100" as="geometry"/>
        </mxCell>

        <mxCell id="store-db" value="🗄 RDB&#xa;PostgreSQL&#xa;・ジョブ状態&#xa;・トランスクリプト本体&#xa;・話者ID/タイムスタンプ" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#9673a6;fontSize=10;verticalAlign=middle;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="900" y="520" width="250" height="100" as="geometry"/>
        </mxCell>

        <mxCell id="store-redis" value="⚡ Redis&#xa;・ジョブキュー&#xa;・WebSocket 状態&#xa;・レート制限カウンタ" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#9673a6;fontSize=10;verticalAlign=middle;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="640" y="630" width="250" height="80" as="geometry"/>
        </mxCell>

        <mxCell id="store-vault" value="🔐 Secrets Vault&#xa;HashiCorp Vault / AWS Secrets Manager&#xa;・API トークン / JWT 鍵 / DB 認証" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#9673a6;fontSize=10;verticalAlign=middle;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="900" y="630" width="250" height="80" as="geometry"/>
        </mxCell>

        <!-- Arrows: Client → Edge -->
        <mxCell id="arr-client-edge" value="HTTPS / WSS" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#6c8ebf;strokeWidth=2;endArrow=blockThin;endFill=1;startArrow=blockThin;startFill=1;fontSize=10;fontColor=#6c8ebf;labelBackgroundColor=#FFFFFF;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" parent="1" source="client-box" target="edge-box">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Arrows: Edge → App -->
        <mxCell id="arr-edge-app" value="内部 HTTP / gRPC" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#82b366;strokeWidth=2;endArrow=blockThin;endFill=1;startArrow=blockThin;startFill=1;fontSize=10;fontColor=#82b366;labelBackgroundColor=#FFFFFF;exitX=1;exitY=0.4;exitDx=0;exitDy=0;entryX=0;entryY=0.3;entryDx=0;entryDy=0;" edge="1" parent="1" source="edge-box" target="app-box">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Arrows: App → Inference -->
        <mxCell id="arr-app-inf" value="vLLM / OpenAI 互換 API" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#b85450;strokeWidth=2;endArrow=blockThin;endFill=1;startArrow=blockThin;startFill=1;fontSize=10;fontColor=#b85450;labelBackgroundColor=#FFFFFF;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" parent="1" source="app-box" target="inf-box">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Arrows: App → Storage -->
        <mxCell id="arr-app-store" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#9673a6;strokeWidth=2;endArrow=blockThin;endFill=1;startArrow=blockThin;startFill=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.3;entryY=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="app-box" target="store-box">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Arrows: Inference → Storage -->
        <mxCell id="arr-inf-store" value="生成音声保存" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#9673a6;strokeWidth=1;endArrow=blockThin;endFill=1;dashed=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.85;entryY=0;entryDx=0;entryDy=0;fontSize=9;fontColor=#9673a6;labelBackgroundColor=#FFFFFF;" edge="1" parent="1" source="inf-box" target="store-box">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Bottom note -->
        <mxCell id="bottom-note" value="🔒 セキュリティ境界: クライアントは音声と認証トークンのみ保持。生のモデルウェイトと API キーはサーバ側 Vault に格納。&#xa;💡 端末側は録音/再生に専念することで iPad/iPhone の電力消費を最小化し、推論性能はサーバ GPU で確保する。" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;verticalAlign=middle;align=center;fontStyle=2;" vertex="1" parent="1">
          <mxGeometry x="40" y="735" width="1120" height="35" as="geometry"/>
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>

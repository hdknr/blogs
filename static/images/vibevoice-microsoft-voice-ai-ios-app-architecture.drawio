        </mxCell>
        <mxCell id="audio-session" value="AVAudioSession (.playAndRecord, .allowBluetooth)&#xa;Background Mode: Audio で背景録音" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#b85450;fontSize=9;verticalAlign=middle;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="60" y="745" width="310" height="35" as="geometry"/>
        </mxCell>
        <mxCell id="audio-chunker" value="ChunkerActor — 30秒×5秒重複&#xa;AsyncStream&lt;AudioChunk&gt; を発行" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#b85450;fontSize=9;verticalAlign=middle;align=left;spacingLeft=8;fontFamily=monospace;" vertex="1" parent="1">
          <mxGeometry x="60" y="785" width="310" height="35" as="geometry"/>
        </mxCell>
        <mxCell id="audio-vad" value="任意: SFSpeechRecognizer ローカル ASR&#xa;Quick 渋滞時のフォールバック字幕" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#b85450;fontSize=9;verticalAlign=middle;align=left;spacingLeft=8;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="60" y="822" width="310" height="30" as="geometry"/>
        </mxCell>

        <!-- Network sub-block -->
        <mxCell id="net-box" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#b85450;strokeWidth=1;" vertex="1" parent="1">
          <mxGeometry x="385" y="675" width="320" height="180" as="geometry"/>
        </mxCell>
        <mxCell id="net-title" value="🌐 Network" style="text;html=1;fontSize=11;fontStyle=1;align=left;verticalAlign=middle;fontColor=#a02c39;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="390" y="680" width="300" height="20" as="geometry"/>
        </mxCell>
        <mxCell id="net-ws" value="WebSocketClient (Actor)&#xa;URLSessionWebSocketTask&#xa;・自動再接続（指数バックオフ）&#xa;・heartbeat ping/pong" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#b85450;fontSize=9;verticalAlign=middle;align=left;spacingLeft=8;fontFamily=monospace;" vertex="1" parent="1">
          <mxGeometry x="390" y="705" width="310" height="55" as="geometry"/>
        </mxCell>
        <mxCell id="net-rest" value="APIClient (struct)&#xa;async URLSession.data(for:)&#xa;・JWT 自動付与&#xa;・リトライ + サーキットブレーカ" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#b85450;fontSize=9;verticalAlign=middle;align=left;spacingLeft=8;fontFamily=monospace;" vertex="1" parent="1">
          <mxGeometry x="390" y="765" width="310" height="55" as="geometry"/>
        </mxCell>
        <mxCell id="net-monitor" value="NWPathMonitor 接続劣化検知" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#b85450;fontSize=9;verticalAlign=middle;align=left;spacingLeft=8;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="390" y="822" width="310" height="30" as="geometry"/>
        </mxCell>

        <!-- Auth + Persistence sub-block -->
        <mxCell id="auth-box" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#b85450;strokeWidth=1;" vertex="1" parent="1">
          <mxGeometry x="715" y="675" width="320" height="180" as="geometry"/>
        </mxCell>
        <mxCell id="auth-title" value="🔐 Auth + Persistence" style="text;html=1;fontSize=11;fontStyle=1;align=left;verticalAlign=middle;fontColor=#a02c39;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="720" y="680" width="300" height="20" as="geometry"/>
        </mxCell>
        <mxCell id="auth-cognito" value="AWSCognitoIdentityProvider&#xa;Hosted UI / SRP / MFA&#xa;Token Refresh タスク" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#b85450;fontSize=9;verticalAlign=middle;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="720" y="705" width="310" height="55" as="geometry"/>
        </mxCell>
        <mxCell id="auth-keychain" value="KeychainStore&#xa;ID/Access/Refresh Token&#xa;kSecAttrAccessibleAfterFirstUnlock" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#b85450;fontSize=9;verticalAlign=middle;align=left;spacingLeft=8;fontFamily=monospace;" vertex="1" parent="1">
          <mxGeometry x="720" y="765" width="310" height="55" as="geometry"/>
        </mxCell>
        <mxCell id="auth-data" value="SwiftData: Session / Minute / Hotword&#xa;ローカル音声バッファ (FileManager)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#b85450;fontSize=9;verticalAlign=middle;align=left;spacingLeft=8;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="720" y="822" width="310" height="30" as="geometry"/>
        </mxCell>

        <!-- Lifecycle + Push sub-block -->
        <mxCell id="life-box" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#b85450;strokeWidth=1;" vertex="1" parent="1">
          <mxGeometry x="1045" y="675" width="310" height="180" as="geometry"/>
        </mxCell>
        <mxCell id="life-title" value="🔁 Lifecycle / Background" style="text;html=1;fontSize=11;fontStyle=1;align=left;verticalAlign=middle;fontColor=#a02c39;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="1050" y="680" width="300" height="20" as="geometry"/>
        </mxCell>
        <mxCell id="life-bg" value="BGTaskScheduler&#xa;ネットワーク復帰時にチャンク再送&#xa;失敗チャンクを localStore からリプレイ" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#b85450;fontSize=9;verticalAlign=middle;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="1050" y="705" width="300" height="55" as="geometry"/>
        </mxCell>
        <mxCell id="life-push" value="UNUserNotificationCenter + APNs&#xa;確定議事録生成完了の通知&#xa;(EventBridge → SNS → APNs)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#b85450;fontSize=9;verticalAlign=middle;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="1050" y="765" width="300" height="55" as="geometry"/>
        </mxCell>
        <mxCell id="life-app" value="ScenePhase 連携 — 録音は前面/背景/中断対応" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#b85450;fontSize=9;verticalAlign=middle;align=left;spacingLeft=8;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="1050" y="822" width="300" height="30" as="geometry"/>
        </mxCell>

        <!-- Arrow: layered top-down -->
        <mxCell id="arrow-down" value="依存方向: View → ViewModel → UseCase → Repository protocol（実装は Infra で差し込み）" style="text;html=1;fontSize=10;align=center;verticalAlign=middle;fontColor=#444444;fontStyle=2;" vertex="1" parent="1">

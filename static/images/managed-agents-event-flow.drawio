<mxfile host="draw.io">
  <diagram name="CMA Event Flow" id="cma-event-flow">
    <mxGraphModel dx="1200" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1100" pageHeight="500" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- User -->
        <mxCell id="user" value="ユーザー" style="shape=actor;whiteSpace=wrap;html=1;fontSize=13;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="30" y="160" width="60" height="80" as="geometry" />
        </mxCell>

        <!-- Developer App -->
        <mxCell id="app-group" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;dashed=1;verticalAlign=top;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="160" y="100" width="200" height="200" as="geometry" />
        </mxCell>
        <mxCell id="app-label" value="開発者のアプリケーション" style="text;html=1;align=center;verticalAlign=top;resizable=0;points=[];autosize=1;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="175" y="108" width="170" height="26" as="geometry" />
        </mxCell>
        <mxCell id="chatbot" value="チャットボット&#xa;/ Web UI" style="rounded=1;whiteSpace=wrap;html=1;fontSize=12;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
          <mxGeometry x="190" y="145" width="140" height="45" as="geometry" />
        </mxCell>
        <mxCell id="api-client" value="Anthropic SDK&#xa;(API クライアント)" style="rounded=1;whiteSpace=wrap;html=1;fontSize=12;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
          <mxGeometry x="190" y="220" width="140" height="45" as="geometry" />
        </mxCell>

        <!-- Arrow: User -> Chatbot -->
        <mxCell id="e1" value="メッセージ" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;fontSize=11;strokeColor=#6c8ebf;exitX=1;exitY=0.3;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" parent="1" source="user" target="chatbot">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Arrow: Chatbot -> API Client -->
        <mxCell id="e2" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;fontSize=11;strokeColor=#d6b656;" edge="1" parent="1" source="chatbot" target="api-client">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Anthropic API boundary -->
        <mxCell id="api-boundary" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;dashed=1;verticalAlign=top;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="440" y="60" width="620" height="340" as="geometry" />
        </mxCell>
        <mxCell id="api-boundary-label" value="Anthropic Cloud (Managed Agents)" style="text;html=1;align=center;verticalAlign=top;resizable=0;points=[];autosize=1;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="530" y="68" width="260" height="26" as="geometry" />
        </mxCell>

        <!-- Session -->
        <mxCell id="session" value="Session&#xa;(イベントログ)" style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=10;fontSize=12;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1">
          <mxGeometry x="490" y="160" width="120" height="70" as="geometry" />
        </mxCell>

        <!-- Brain -->
        <mxCell id="brain-group" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;dashed=0;verticalAlign=top;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="680" y="110" width="160" height="130" as="geometry" />
        </mxCell>
        <mxCell id="brain-label" value="Brain" style="text;html=1;align=center;verticalAlign=top;resizable=0;points=[];autosize=1;fontSize=13;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="735" y="115" width="50" height="26" as="geometry" />
        </mxCell>
        <mxCell id="harness" value="Agent Harness" style="rounded=1;whiteSpace=wrap;html=1;fontSize=11;fillColor=#e1d5e7;strokeColor=#9673a6;" vertex="1" parent="1">
          <mxGeometry x="700" y="145" width="120" height="30" as="geometry" />
        </mxCell>
        <mxCell id="claude" value="Claude (LLM)" style="rounded=1;whiteSpace=wrap;html=1;fontSize=11;fillColor=#e1d5e7;strokeColor=#9673a6;" vertex="1" parent="1">
          <mxGeometry x="700" y="190" width="120" height="30" as="geometry" />
        </mxCell>

        <!-- Hands -->
        <mxCell id="hands-group" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;dashed=0;verticalAlign=top;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="900" y="110" width="140" height="130" as="geometry" />
        </mxCell>
        <mxCell id="hands-label" value="Hands" style="text;html=1;align=center;verticalAlign=top;resizable=0;points=[];autosize=1;fontSize=13;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="945" y="115" width="50" height="26" as="geometry" />
        </mxCell>
        <mxCell id="sandbox" value="Sandbox" style="rounded=1;whiteSpace=wrap;html=1;fontSize=11;fillColor=#f8cecc;strokeColor=#b85450;" vertex="1" parent="1">
          <mxGeometry x="915" y="145" width="110" height="30" as="geometry" />
        </mxCell>
        <mxCell id="tools" value="Tools / MCP" style="rounded=1;whiteSpace=wrap;html=1;fontSize=11;fillColor=#f8cecc;strokeColor=#b85450;" vertex="1" parent="1">
          <mxGeometry x="915" y="190" width="110" height="30" as="geometry" />
        </mxCell>

        <!-- Arrow: API Client -> Session (POST events) -->
        <mxCell id="e3" value="② POST /sessions/{id}/events" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;fontSize=10;strokeColor=#82b366;fontStyle=1;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" parent="1" source="api-client" target="session">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="420" y="242" as="sourcePoint" />
          </mxGeometry>
        </mxCell>

        <!-- Arrow: Session -> Brain (getEvents) -->
        <mxCell id="e4" value="③ getEvents()" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;fontSize=10;strokeColor=#9673a6;fontStyle=1;" edge="1" parent="1" source="session" target="harness">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Arrow: Brain -> Hands (execute) -->
        <mxCell id="e5" value="④ execute()" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;fontSize=10;strokeColor=#b85450;fontStyle=1;" edge="1" parent="1" source="claude" target="sandbox">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Arrow: Brain -> Session (emitEvent) -->
        <mxCell id="e6" value="⑤ emitEvent()" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;fontSize=10;strokeColor=#9673a6;dashed=1;entryX=0.5;entryY=1;entryDx=0;entryDy=0;exitX=0.5;exitY=1;exitDx=0;exitDy=0;" edge="1" parent="1" source="brain-group" target="session">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="760" y="320" />
              <mxPoint x="550" y="320" />
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- Arrow: Session -> API Client (SSE stream) -->
        <mxCell id="e7" value="⑥ GET /sessions/{id}/stream (SSE)" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;fontSize=10;strokeColor=#82b366;dashed=1;fontStyle=1;exitX=0;exitY=1;exitDx=0;exitDy=0;" edge="1" parent="1" source="session" target="api-client">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="490" y="360" />
              <mxPoint x="260" y="360" />
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- Arrow: App -> User (response) -->
        <mxCell id="e8" value="⑦ 応答" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;fontSize=11;strokeColor=#6c8ebf;dashed=1;exitX=0;exitY=0.5;exitDx=0;exitDy=0;entryX=1;entryY=0.7;entryDx=0;entryDy=0;" edge="1" parent="1" source="chatbot" target="user">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="140" y="168" />
              <mxPoint x="140" y="216" />
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- Step labels -->
        <mxCell id="note1" value="① ユーザーがチャットでメッセージを送信" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=1;fontSize=11;fontColor=#666666;" vertex="1" parent="1">
          <mxGeometry x="30" y="420" width="280" height="26" as="geometry" />
        </mxCell>
        <mxCell id="note2" value="②〜③ アプリが API 経由でイベントを送信 → Brain が取得" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=1;fontSize=11;fontColor=#666666;" vertex="1" parent="1">
          <mxGeometry x="320" y="420" width="330" height="26" as="geometry" />
        </mxCell>
        <mxCell id="note3" value="④〜⑤ Brain がオーケストレーション（ツール実行・結果記録）" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=1;fontSize=11;fontColor=#666666;" vertex="1" parent="1">
          <mxGeometry x="660" y="420" width="330" height="26" as="geometry" />
        </mxCell>
        <mxCell id="note4" value="⑥〜⑦ SSE で結果をストリーム → アプリがユーザーに応答" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=1;fontSize=11;fontColor=#666666;" vertex="1" parent="1">
          <mxGeometry x="30" y="446" width="330" height="26" as="geometry" />
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
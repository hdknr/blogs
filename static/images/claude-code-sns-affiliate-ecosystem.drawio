        <mxCell id="e5" value="③ プロンプト / 自動化設定" style="endArrow=classic;html=1;fontSize=12;labelBackgroundColor=#ffffff;" edge="1" parent="1" source="media" target="claude">
          <mxGeometry relative="1" as="geometry" />

        <mxCell id="e2" value="⑦ 成果通知" style="endArrow=classic;html=1;fontSize=12;labelBackgroundColor=#ffffff;exitX=1;exitY=0.75;entryX=0;entryY=0.75;" edge="1" parent="1" source="advertiser" target="asp">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e3" value="② アフィリンク取得" style="endArrow=classic;html=1;fontSize=12;labelBackgroundColor=#ffffff;exitX=0;exitY=0.25;entryX=1;entryY=0.25;" edge="1" parent="1" source="media" target="asp">
          <mxGeometry relative="1" as="geometry" />

        <mxCell id="e6" value="④ 自動投稿（アフィリンク含む）" style="endArrow=classic;html=1;fontSize=12;labelBackgroundColor=#ffffff;" edge="1" parent="1" source="claude" target="sns">
          <mxGeometry relative="1" as="geometry" />

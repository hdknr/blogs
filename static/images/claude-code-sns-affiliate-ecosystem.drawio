        <mxCell id="e4" value="⑧ 報酬支払い" style="endArrow=classic;html=1;fontSize=12;labelBackgroundColor=#ffffff;exitX=1;exitY=0.75;entryX=0;entryY=0.75;" edge="1" parent="1" source="asp" target="media">
          <mxGeometry relative="1" as="geometry" />

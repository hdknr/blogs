        <mxCell id="v1b" value="◎&lt;br&gt;直接的" style="ellipse;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="540" y="110" width="80" height="50" as="geometry"/>
